#include <WiFi.h>
#include <WebServer.h>
#include <Arduino.h>
#include <ESP32Servo.h>
#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>
#include <LittleFS.h>
const char* ssid = "Andrew Nguyen";
const char* pass = "chienhd123";

#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64
#define OLED_ADDRESS 0x3C
bool oledOK = false;
Adafruit_SSD1306 displayOled(SCREEN_WIDTH,SCREEN_HEIGHT,&Wire,-1);
WebServer server(80); // create a web server
Servo sg90;
// pinout for parking LEDs
int ledPins[6] = {16, 17, 18, 19, 25, 26};
String lastMessage = "No message yet"; //for parking spots

String spotStatus[6] = {"unknown","unknown","unknown","unknown","unknown","unknown"};
String oledMassage;
String plateMsg="";
// ================== PLATE LED + LIST ==================
const int servo_pinout = 23;   // LED bật khi biển số match

// List biển số (3 số) - sửa theo ý bạn
String allowedPlates[] = {"A6", "V3", "C1",};
const int ALLOWED_COUNT = sizeof(allowedPlates) / sizeof(allowedPlates[0]);

String lastPlate = "";         
bool lastPlateOk = false;       

// ✅ TIMEOUT: Turn off LED when no valid plate
unsigned long lastValidPlateTime = 0;
const unsigned long PLATE_TIMEOUT = 4000; // ms (500~1500 tuỳ camera/network)

int deniedStreak = 0;
const int DENIED_STREAK_TO_CLOSE = 3; 

unsigned long lastWebVisitTime = 0;
const unsigned long WEB_GRACE_MS = 6000; // 3s ân hạn sau khi mở web

unsigned long lastPlateSeenTime = 0;
const unsigned long PLATE_SEEN_TIMEOUT = 6000; // 8s: không thấy request /plate thì đóng
bool plateAllowed(const String &n) {
  for (int i = 0; i < ALLOWED_COUNT; i++) {
    if (n == allowedPlates[i]) return true;
  }
  return false;
}

void updatePlateMsg()
{
  plateMsg="Plate:";
  if(lastPlate.length()>0)
  {
    plateMsg+=lastPlate;
  }
  else{
    plateMsg+="No detection";
    return;
  }
  if(lastPlateOk)
  {
    plateMsg+=" matched";
  }
  else
  {
    plateMsg+=" not matched";
  }
}

void handlePlate() {

  if (!server.hasArg("n")) {
    server.send(200, "text/plain", "Plate page");
    return;
  }

  String n = server.arg("n");
  n.trim();
  lastPlate = n;

  bool ok = plateAllowed(n);

  Serial.print("Plate received: ");
  Serial.print(n);
  Serial.print(" -> ");
  Serial.println(ok ? "ALLOWED" : "DENIED");

  if (ok) {
    // ✅ MỞ CỬA
    sg90.write(90);
    delay(10);

    lastValidPlateTime = millis();
    deniedStreak = 0;          // reset vì đúng
    lastPlateOk = true;
  } 
  else {
    // ❗ KHÔNG đóng ngay, chỉ tăng đếm nếu đang mở
    if (lastPlateOk) {
      deniedStreak++;

      if (deniedStreak >= DENIED_STREAK_TO_CLOSE) {
        sg90.write(0);
        delay(10);

        lastPlateOk = false;
        deniedStreak = 0;

        Serial.println("Too many denied -> SERVO CLOSED");
      }
    }
  }
  lastPlateSeenTime = millis();
  updatePlateMsg();
  server.send(200, "text/plain", ok ? "ALLOWED" : "DENIED");
}
// ======================================================

// send s=111111
void handleLed() {
  if (!server.hasArg("s")) {
    server.send(400, "text/plain", "Missing s");
    return;
  }

  String s = server.arg("s");

  if (s.length() != 6) {
    server.send(400, "text/plain", "Need 6 chars");
    return;
  }

  for (int i = 0; i < 6; i++) {
    if (s[i] == '1')
      digitalWrite(ledPins[i], HIGH);   // FREE -> LED ON
    else
      digitalWrite(ledPins[i], LOW);    // OCCUPIED -> LED OFF
  }
 
  server.send(200, "text/plain", "OK");
}

void handleMsg() {
  if (!(server.hasArg("spot") && server.hasArg("status"))) {
    server.send(400, "text/plain", "Missing spot and status");
    return;
  }

  int spot = server.arg("spot").toInt();   // 1..6
  String status = server.arg("status");
  status.toLowerCase();

  if (spot >= 1 && spot <= 6) {
    spotStatus[spot - 1] = status;
  }

  // Update lastMessage for handleRoot()
  String html = "";
  oledMassage="";
  bool freeFlag = false;

  for (int i = 0; i < 6; i++) {
    if (spotStatus[i] == "free") {
      freeFlag = true;
      html += "Spot " + String(i + 1) + " is FREE ";
     
      html += "<button onclick='toggleSpot(" + String(i + 1) + ")'>Navigation</button><br>";
      html += "<div id='imgBox" + String(i + 1) + "' style='display:none; margin:8px 0;'>";
      html += "<img id='img" + String(i + 1) + "' width='600'>";
      html += "</div>";



      oledMassage+= "Spot " + String(i + 1) + " is FREE\n";
    }
  }

  if (!freeFlag) {
    html = "No free spots";
    oledMassage="No free spots";
  }
  
  lastMessage = html;
  server.send(200, "text/plain", "OK");
}

void handleRoot() {
  updatePlateMsg();

  String html = R"rawliteral(
<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <script>
      function toggleSpot(i)
      {
        // hide all safely
        for(let k=1;k<=6;k++){
          let box = document.getElementById("imgBox"+k);
          if(box) box.style.display="none";
        }

        let box = document.getElementById("imgBox"+i);
        let img = document.getElementById("img"+i);

        if(box && img){
          box.style.display="block";
          img.src="/img?i="+i+"&t="+Date.now(); // refresh
        }
      }
    </script>
  </head>
  <body>
    <h1>Smart Parking</h1>
    <p>{{plateMsg}}</p>
    <div>{{parkingMsg}}</div>
  </body>
</html>
)rawliteral";

  html.replace("{{plateMsg}}", plateMsg);
  html.replace("{{parkingMsg}}", lastMessage);
  lastWebVisitTime = millis();
  server.send(200, "text/html", html);
}
void handleImg() {
  if (!server.hasArg("i")) {
    server.send(400, "text/plain", "Missing i");
    return;
  }
  int imageNumber = server.arg("i").toInt();
  if (imageNumber < 1 || imageNumber > 6) {
    server.send(400, "text/plain", "Spot must be 1..6");
    return;
  }

  String path = "/spot" + String(imageNumber) + ".jpg";   // /spot1.jpg ... /spot6.jpg
  File f = LittleFS.open(path, "r");
  if (!f) {
    server.send(404, "text/plain", "Image not found: " + path);
    return;
  }

  server.streamFile(f, "image/jpeg");
  f.close();
}
void handleSpotPage() {
  if (!server.hasArg("i")) {
    server.send(400, "text/plain", "Missing i");
    return;
  }
  int i = server.arg("i").toInt();
  if (i < 1 || i > 6) {
    server.send(400, "text/plain", "Spot must be 1..6");
    return;
  }

  String status = spotStatus[i - 1];
  String imgUrl = "/img?i=" + String(i);

  String html = R"rawliteral(
<!DOCTYPE html>
<html>
  <head><meta charset="utf-8"><title>Spot</title></head>
  <body>
    <h2>Spot {{SPOT}}</h2>
    <p>Status: <b>{{STATUS}}</b></p>
    <p><a href="/">Back</a></p>
    <img src="{{IMG}}" style="width:100%;max-width:900px;border:2px solid #333;">
  </body>
</html>
)rawliteral";

  html.replace("{{SPOT}}", String(i));
  html.replace("{{STATUS}}", status);
  html.replace("{{IMG}}", imgUrl);

  server.send(200, "text/html", html);
}




void setup() {
  Serial.begin(115200);
  if (!LittleFS.begin(true)) {
  Serial.println("LittleFS mount FAILED");
} else {
  Serial.println("LittleFS mounted OK");
}
  for (int i = 0; i < 6; i++) {
    pinMode(ledPins[i], OUTPUT);
    digitalWrite(ledPins[i], LOW);
  }
  //servo
  pinMode(servo_pinout, OUTPUT);
  digitalWrite(servo_pinout, LOW);
  sg90.setPeriodHertz(50);
  sg90.attach(servo_pinout,500,2400);
  sg90.write(0);
  delay(200);
  //wifi
  WiFi.mode(WIFI_STA);
  WiFi.begin(ssid, pass);
  Serial.print("Connecting");
  while (WiFi.status() != WL_CONNECTED) {
    delay(300);
    Serial.print(".");
  }
  lastPlateSeenTime = millis();
  Serial.println();
  Serial.print("ESP32 IP: ");
  Serial.println(WiFi.localIP());
  server.on("/", handleRoot);
  server.on("/led", handleLed);
  server.on("/msg", handleMsg);
  server.on("/plate", handlePlate);
  server.on("/img", handleImg);
  server.on("/spot", handleSpotPage);
  server.begin();

  //OLED
   Wire.begin(21, 22);
  oledOK = displayOled.begin(SSD1306_SWITCHCAPVCC, OLED_ADDRESS);
  if (!oledOK) {
    Serial.println("OLED init FAILED");
    while (true) delay(1000);
  }
  displayOled.clearDisplay();
  displayOled.setTextColor(SSD1306_WHITE);
  displayOled.setTextSize(1);
  displayOled.setCursor(0,0);
}

void loop() {
  server.handleClient();
  if (oledOK) {
    displayOled.clearDisplay();
    displayOled.setTextColor(SSD1306_WHITE);
    displayOled.setTextSize(1);
    displayOled.setCursor(0, 0);
    displayOled.println("Team 2:Parking system");
    displayOled.println(plateMsg);
    displayOled.print(oledMassage);
    displayOled.display();   
  }
  // ✅ AUTO CLOSE SERVO if no valid plate recently
bool webGrace = (millis() - lastWebVisitTime) < WEB_GRACE_MS;

// ✅ chỉ đóng khi: đang mở + không ai gửi /plate trong PLATE_SEEN_TIMEOUT + không trong lúc vừa mở web
if (!webGrace && lastPlateOk && (millis() - lastPlateSeenTime > PLATE_SEEN_TIMEOUT)) {
  sg90.write(0);
  lastPlateOk = false;
  lastPlate = "";
  deniedStreak = 0;
  updatePlateMsg();
  Serial.println("Plate seen timeout -> SERVO CLOSED");
}
  delay(50);
 
  
}
